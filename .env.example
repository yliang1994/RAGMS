# Copy this file to `.env` and fill in only the values you need.
# The loader reads `.env` from the same directory as `settings.yaml`.

# Core runtime
RAGMS_APP_NAME=ragms
RAGMS_ENVIRONMENT=development

# Paths
RAGMS_PATHS__PROJECT_ROOT=.
RAGMS_PATHS__DATA_DIR=data
RAGMS_PATHS__LOGS_DIR=logs

# LLM
RAGMS_LLM__PROVIDER=openai
RAGMS_LLM__MODEL=gpt-4.1-mini
RAGMS_LLM__API_KEY=
RAGMS_LLM__BASE_URL=

# Dense embedding
RAGMS_EMBEDDING__PROVIDER=openai
RAGMS_EMBEDDING__MODEL=text-embedding-3-small
RAGMS_EMBEDDING__API_KEY=

# Vision LLM for image captioning
RAGMS_VISION_LLM__PROVIDER=auto
RAGMS_VISION_LLM__MODEL=gpt-4.1-mini
RAGMS_VISION_LLM__API_KEY=
RAGMS_VISION_LLM__BASE_URL=

# Vector store
RAGMS_VECTOR_STORE__BACKEND=chroma
RAGMS_VECTOR_STORE__COLLECTION=default

# Retrieval
RAGMS_RETRIEVAL__STRATEGY=hybrid
RAGMS_RETRIEVAL__FUSION_ALGORITHM=rrf
RAGMS_RETRIEVAL__RERANK_BACKEND=disabled

# Evaluation
RAGMS_EVALUATION__BACKENDS=custom_metrics

# SQLite metadata storage
RAGMS_STORAGE__SQLITE__PATH=data/metadata/ragms.db

# Observability
RAGMS_OBSERVABILITY__ENABLED=true
RAGMS_OBSERVABILITY__LOG_FILE=logs/traces.jsonl
RAGMS_OBSERVABILITY__LOG_LEVEL=INFO

# Dashboard
RAGMS_DASHBOARD__ENABLED=true
RAGMS_DASHBOARD__PORT=8501
RAGMS_DASHBOARD__TRACES_FILE=logs/traces.jsonl
